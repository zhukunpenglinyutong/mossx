{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ccgui",
  "version": "0.4.15",
  "identifier": "com.zhukunpenglinyutong.ccgui",
  "build": {
    "beforeDevCommand": "node scripts/tauri-dev-frontend.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: asset: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:* https: wss:; img-src 'self' asset: data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; font-src 'self' data:; media-src 'self' data: blob:; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "infoplist/**/*": "./",
      "../dist/*": "dist/",
      "../dist/assets/**/*": "dist/assets/"
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist",
      "dmg": {
        "background": "icons/dmg-background.png",
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "linux": {
      "deb": {
        "desktopTemplate": null
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCOUY2RkIzOUFFNTBBQjgKUldTNEN1V2FzMitmeXpxVWkxMXUrM05UVHRJQTNaTHNZcVo4SktSQUJNSVM2VDEzSzVtaUhHWGcK",
      "endpoints": [
        "https://github.com/zhukunpenglinyutong/desktop-cc-gui/releases/latest/download/latest.json"
      ]
    }
  }
}

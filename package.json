{
  "name": "ccgui",
  "private": true,
  "version": "0.4.16",
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/enforce-package-manager.mjs npm",
    "dev": "npm run ensure:dev-port && vite",
    "build": "tsc && vite build",
    "build:appimage": "NO_STRIP=1 tauri build --bundles appimage",
    "build:mac-arm64": "node scripts/build-platform.mjs mac-arm64",
    "build:mac-x64": "node scripts/build-platform.mjs mac-x64",
    "build:mac-universal": "node scripts/build-platform.mjs mac-universal",
    "build:win-x64": "node scripts/build-platform.mjs win-x64",
    "build:linux-x64": "node scripts/build-platform.mjs linux-x64",
    "build:linux-arm64": "node scripts/build-platform.mjs linux-arm64",
    "build:all": "node scripts/build-platform.mjs all",
    "doctor": "node scripts/doctor.mjs",
    "doctor:strict": "npm run check:runtime-contracts && npm run check:branding && node scripts/doctor.mjs --strict",
    "doctor:win": "npm run check:runtime-contracts && npm run check:branding && node scripts/doctor.mjs --strict",
    "check:app-shell:runtime-contract": "node scripts/check-app-shell-runtime-contract.mjs",
    "check:git-history:runtime-contract": "node scripts/check-git-history-runtime-contract.mjs",
    "check:git-history:static-imports": "node scripts/check-refactor-imports.mjs src/features/git-history/components/git-history-panel/components",
    "check:branding": "node scripts/check-branding.mjs",
    "check:runtime-contracts": "npm run check:app-shell:runtime-contract && npm run check:git-history:runtime-contract",
    "ensure:dev-port": "node scripts/ensure-dev-port.mjs",
    "check:large-files": "node scripts/check-large-files.mjs --policy-file scripts/check-large-files.policy.json --baseline-file docs/architecture/large-file-baseline.json --scope fail --mode report",
    "check:large-files:baseline": "node scripts/check-large-files.mjs --policy-file scripts/check-large-files.policy.json --scope fail --mode report --markdown-output docs/architecture/large-file-baseline.md --baseline-output docs/architecture/large-file-baseline.json",
    "check:large-files:near-threshold": "node scripts/check-large-files.mjs --policy-file scripts/check-large-files.policy.json --baseline-file docs/architecture/large-file-baseline.json --scope warn --mode warn",
    "check:large-files:near-threshold:baseline": "node scripts/check-large-files.mjs --policy-file scripts/check-large-files.policy.json --scope warn --mode report --markdown-output docs/architecture/large-file-near-threshold-watchlist.md",
    "check:large-files:ci": "node scripts/check-large-files.mjs --policy-file scripts/check-large-files.policy.json --baseline-file docs/architecture/large-file-baseline.json --scope fail --mode warn",
    "check:large-files:gate": "node scripts/check-large-files.mjs --policy-file scripts/check-large-files.policy.json --baseline-file docs/architecture/large-file-baseline.json --scope fail --mode fail",
    "check:heavy-test-noise": "node scripts/check-heavy-test-noise.mjs --run",
    "perf:realtime:report": "npm exec vite-node -- scripts/realtime-perf-report.ts",
    "perf:realtime:boundary-guard": "vitest run src/features/threads/contracts/realtimeBoundaryGuard.test.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "node scripts/test-batched.mjs",
    "test:integration": "node scripts/test-batched.mjs --include-heavy",
    "test:layout-guard": "vitest run src/styles/layout-swapped-platform-guard.test.ts",
    "test:memory-kind-contract:ts": "vitest run src/features/project-memory/utils/memoryKindClassifier.contract.test.ts",
    "test:memory-kind-contract:rust": "cargo test --manifest-path src-tauri/Cargo.toml classify_kind_matches_contract_samples",
    "test:memory-kind-contract": "npm run test:memory-kind-contract:ts && npm run test:memory-kind-contract:rust",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:hot": "tauri dev",
    "tauri:dev": "npm run doctor:strict && tauri dev",
    "tauri:build": "npm run doctor:strict && tauri build",
    "tauri:dev:win": "npm run doctor:win && tauri dev --config src-tauri/tauri.windows.conf.json",
    "tauri:build:win": "npm run doctor:win && tauri build --config src-tauri/tauri.windows.conf.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@lobehub/icons": "^4.9.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "~2.9.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "~2.9.0",
    "@uiw/react-codemirror": "^4.25.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "antd": "^6.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.34.0",
    "i18next": "^25.8.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.12.2",
    "pdfjs-dist": "^5.6.205",
    "prismjs": "^1.30.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "tauri-plugin-liquid-glass-api": "^0.1.6",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.5.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^27.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "xmlchars": "file:vendor/xmlchars",
    "yocto-queue": "file:vendor/yocto-queue"
  }
}
